<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Propuestas de Logo - Saris</title>
        <style>
            body {
                background-color: #f5f5f5;
                font-family: "Inter", sans-serif;
                display: flex;
                flex-direction: column;
                align-items: center;
                padding: 50px 20px;
                color: #2d2424;
            }
            .container {
                max-width: 800px;
                width: 100%;
                display: grid;
                gap: 40px;
            }
            .card {
                background: #fdfbf7;
                padding: 60px;
                border-radius: 30px;
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                border: 1px solid rgba(166, 110, 94, 0.1);
            }
            .label {
                margin-top: 30px;
                font-size: 14px;
                font-weight: bold;
                color: #a66e5e;
                text-transform: uppercase;
                letter-spacing: 2px;
            }
            .desc {
                font-size: 14px;
                color: #666;
                margin-top: 10px;
                text-align: center;
                max-width: 400px;
            }
            .dark {
                background: #2d2424;
                color: #fdfbf7;
            }
        </style>
        <link
            href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;600&family=Inter:wght@400;700&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <h1
            style="font-family: 'Cormorant Garamond', serif; font-size: 42px; margin-bottom: 40px;"
        >
            Propuestas de Identidad Visual - Saris
        </h1>

        <div class="container">
            <!-- Opción 1 -->
            <div class="card">
                <svg
                    width="120"
                    height="120"
                    viewBox="0 0 100 100"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <circle
                        cx="50"
                        cy="50"
                        r="48"
                        stroke="#A66E5E"
                        stroke-width="0.5"></circle>
                    <path
                        d="M45 35C45 35 55 30 60 40C65 50 45 55 40 65C35 75 55 80 55 80"
                        stroke="#2D2424"
                        stroke-width="3"
                        stroke-linecap="round"></path>
                    <path
                        d="M65 30C67 35 60 40 55 38"
                        stroke="#A66E5E"
                        stroke-width="1"
                        stroke-linecap="round"></path>
                    <circle cx="67" cy="28" r="1.5" fill="#A66E5E"></circle>
                </svg>
                <span
                    style="font-family: 'Cormorant Garamond', serif; font-size: 32px; letter-spacing: 0.3em; color: #2D2424; font-weight: 600; margin-top: 20px;"
                    >SARIS</span
                >
                <div class="label">Propuesta 1: Monograma Botánico</div>
                <p class="desc">
                    Combina la "S" de la marca con una rama de olivo
                    minimalista, simbolizando paz y calidez del hogar.
                </p>
            </div>

            <!-- Opción 2 -->
            <div class="card">
                <div style="display: flex; align-items: baseline; gap: 4px;">
                    <span
                        style="font-family: 'Cormorant Garamond', serif; font-size: 72px; color: #2D2424; font-weight: 300;"
                        >Saris</span
                    >
                    <div
                        style="width: 10px; height: 10px; background: #A66E5E; border-radius: 50%;"
                    >
                    </div>
                </div>
                <div
                    style="width: 150px; height: 1px; background: #A66E5E; opacity: 0.3; margin-top: 10px;"
                >
                </div>
                <div class="label">Propuesta 2: Wordmark Minimalista</div>
                <p class="desc">
                    Enfoque puramente tipográfico de alta gama. El punto
                    terracota añade personalidad y modernidad.
                </p>
            </div>

            <!-- Opción 3 -->
            <div class="card dark">
                <svg
                    width="100"
                    height="100"
                    viewBox="0 0 100 100"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
                >
                    <path
                        d="M30 25C30 25 70 25 70 42C70 59 30 59 30 76C30 76 70 76 70 76"
                        stroke="#FDFBF7"
                        stroke-width="6"
                        stroke-linecap="round"></path>
                    <path
                        d="M45 42L55 42"
                        stroke="#A66E5E"
                        stroke-width="6"
                        stroke-linecap="round"></path>
                </svg>
                <span
                    style="font-family: 'Inter', sans-serif; font-size: 24px; letter-spacing: 0.5em; color: #FDFBF7; font-weight: 200; margin-top: 20px;"
                    >SARIS</span
                >
                <div class="label" style="color: #FDFBF7; opacity: 0.7;">
                    Propuesta 3: Emblema Moderno
                </div>
                <p class="desc" style="color: #FDFBF7; opacity: 0.6;">
                    Un diseño geométrico y abstracto. Las líneas fluidas
                    sugieren telas, suavidad y cuidado personal.
                </p>
            </div>
        </div>
    </body>
</html>
