---
import { and, asc, desc, eq } from 'drizzle-orm'
import Layout from '../layouts/Layout.astro'
import { getDb } from '../db'
import { brands, categories, discounts, productPhotos, products, settings, subcategories } from '../db/schema'
import { resolveDiscount } from '../lib/resolveDiscount'

const db = getDb()

const [
  allCategories,
  allSubcategories,
  rawFeatured,
  activeDiscounts,
  whatsappSetting,
  siteNameSetting,
] = await Promise.all([
  db
    .select({
      id: categories.id,
      name: categories.name,
      slug: categories.slug,
      description: categories.description,
      photoKey: categories.photoKey,
      sortOrder: categories.sortOrder,
    })
    .from(categories)
    .orderBy(asc(categories.sortOrder), asc(categories.name)),

  db
    .select({
      id: subcategories.id,
      name: subcategories.name,
      slug: subcategories.slug,
      categoryId: subcategories.categoryId,
      description: subcategories.description,
      photoKey: subcategories.photoKey,
    })
    .from(subcategories)
    .orderBy(asc(subcategories.sortOrder), asc(subcategories.name)),

  db
    .select({
      id: products.id,
      slug: products.slug,
      name: products.name,
      categoryId: products.categoryId,
      subcategoryId: products.subcategoryId,
      brandId: products.brandId,
      brandName: brands.name,
      basePrice: products.basePrice,
      mainPhotoKey: productPhotos.r2Key,
    })
    .from(products)
    .leftJoin(brands, eq(products.brandId, brands.id))
    .leftJoin(productPhotos, and(eq(productPhotos.productId, products.id), eq(productPhotos.sortOrder, 0)))
    .where(and(eq(products.status, 'active'), eq(products.featured, true)))
    .orderBy(desc(products.createdAt))
    .limit(12),

  db.select().from(discounts).where(eq(discounts.active, true)),

  db.select({ value: settings.value }).from(settings).where(eq(settings.key, 'whatsapp_number')).limit(1),

  db.select({ value: settings.value }).from(settings).where(eq(settings.key, 'site_name')).limit(1),
])

const featuredProducts = rawFeatured.map((p) => {
  const resolved = resolveDiscount(
    { id: p.id, categoryId: p.categoryId, subcategoryId: p.subcategoryId, brandId: p.brandId, basePrice: p.basePrice },
    { color: null, size: null, priceOverride: null },
    activeDiscounts,
  )
  return { ...p, discountedPrice: resolved?.finalPrice ?? null }
})

const whatsappNumber = whatsappSetting[0]?.value ?? ''
const siteName = siteNameSetting[0]?.value ?? 'Saris'

// Mapeo de imágenes locales para categorías (debe estar en el frontmatter por los generics de TS)
const categoryImages: Record<string, string> = {
  'belleza': '/images/categories/belleza.png',
  'joyeria': '/images/categories/joyeria.png',
  'ropa': '/images/categories/ropa.png',
}

// Mapeo de imágenes para subcategorías (Curadas para mantener la estética Saris)
const subcategoryImages: Record<string, string> = {
  'blusas': 'https://images.unsplash.com/photo-1551163943-3f6a855d1153?q=80&w=600&auto=format&fit=crop',
  'anillos': 'https://images.unsplash.com/photo-1605100804763-247f67b3557e?q=80&w=600&auto=format&fit=crop',
  'pantalones': 'https://images.unsplash.com/photo-1594633312681-425c7b97ccd1?q=80&w=600&auto=format&fit=crop',
  'vestidos': 'https://images.unsplash.com/photo-1595777457583-95e059d581b8?q=80&w=600&auto=format&fit=crop',
}

const MXN = new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN', maximumFractionDigits: 0 })

function formatPrice(centavos: number) {
  return MXN.format(centavos / 100)
}
// Lógica dinámica para el número de columnas de subcategorías
const subCount = allSubcategories.length;
const gridColsSm = subCount >= 4 ? 'sm:grid-cols-4' : `sm:grid-cols-${subCount}`;
const gridColsLg = subCount >= 6 ? 'lg:grid-cols-6' : `lg:grid-cols-${subCount}`;

function getCategoryWidth(count: number) {
  if (count === 1) return 'lg:w-full';
  if (count === 2) return 'lg:w-[calc(50%-1rem)]';
  if (count === 3) return 'lg:w-[calc(33.33%-1.5rem)]';
  return 'lg:w-[calc(25%-1.5rem)]';
}
---

<Layout title="Saris" description="Tienda de ropa Saris — Descubre nuestras colecciones">
  <div class="space-y-24 py-4">
    
    {/* Hero Section - Propuesta de Valor */}
    <section class="relative overflow-hidden rounded-[3rem] bg-linen">
      <div class="grid grid-cols-1 lg:grid-cols-2 items-center min-h-[600px]">
        {/* Lado del Texto */}
        <div class="relative z-10 p-8 sm:p-16 lg:p-24 space-y-8 order-2 lg:order-1">
          <div class="space-y-4">
            <p class="text-terracotta font-bold tracking-[0.3em] uppercase text-xs">Un Ritual de Amor Propio</p>
            <h1 class="text-5xl sm:text-7xl font-brand font-bold text-espresso leading-tight">Tu mejor versión, cada día</h1>
            <p class="text-lg sm:text-xl text-espresso/70 font-light leading-relaxed max-w-md">
              Celebramos tu esencia con piezas que realzan tu belleza natural. Porque arreglarse es un acto de amor propio, y tú mereces lo mejor.
            </p>
          </div>
          <div class="flex flex-col gap-4 pt-4">
            <a href="/catalogo" class="btn-primary px-10 py-4 text-lg w-full sm:w-72">
              Descubrir mi estilo
            </a>
            <a href="#productos-destacados" class="inline-flex items-center justify-center rounded-2xl border border-terracotta/20 px-10 py-4 text-lg font-medium text-terracotta hover:bg-terracotta/5 transition-all w-full sm:w-72">
              Ver novedades
            </a>
          </div>
        </div>

        {/* Lado de la Imagen */}
        <div class="relative h-[400px] lg:h-full w-full order-1 lg:order-2 overflow-hidden">
          <img
            src="/images/hero-lifestyle.png"
            alt="Estilo de vida Saris"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-r from-linen lg:via-linen/20 to-transparent pointer-events-none"></div>
        </div>
      </div>
    </section>

    {allCategories.length === 0 ? (
      <div class="py-24 text-center">
        {/* Homepage vacío — sin categorías */}
        <h1 class="text-5xl font-bold text-terracotta mb-6">Bienvenido a {siteName}</h1>
        <p class="text-espresso/60 mb-10 max-w-md mx-auto text-lg">Descubre colecciones curadas pensando en tu hogar y estilo diario.</p>
        <a href="/catalogo" class="btn-primary">
          Ver catálogo
        </a>
      </div>
    ) : (
      <div class="space-y-32">

      {/* Sección de Colecciones Principales */}
      <section class="space-y-12">
        <div class="text-center space-y-4">
          <h2 class="text-4xl sm:text-5xl font-brand font-bold text-espresso">Nuestras Colecciones</h2>
          <p class="text-espresso/60 max-w-2xl mx-auto">Selecciones exclusivas diseñadas para realzar cada faceta de tu estilo personal.</p>
        </div>

        <div class="flex flex-wrap justify-center gap-8">
            {allCategories.map((category) => {
              const displayImage = categoryImages[category.slug] || (category.photoKey ? `/api/media/${category.photoKey}` : null)
              return (
                <a
                  href={`/catalogo?category=${category.id}`}
                  class:list={[
                    'group relative w-full sm:w-[calc(50%-1rem)] aspect-[3/4] overflow-hidden rounded-[2.5rem] bg-linen shadow-sm transition-all duration-700 hover:shadow-xl hover:-translate-y-2',
                    getCategoryWidth(allCategories.length)
                  ]}
                >
                {displayImage ? (
                  <img
                    src={displayImage}
                    alt={category.name}
                    class="absolute inset-0 h-full w-full object-cover transition-transform duration-1000 group-hover:scale-110"
                  />
                ) : (
                  <div class="absolute inset-0 bg-gradient-to-br from-terracotta/10 to-espresso/5" />
                )}
                
                {/* Overlay Gradiente */}
                <div class="absolute inset-0 bg-gradient-to-t from-espresso/60 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity"></div>
                
                {/* Contenido de la Tarjeta */}
                <div class="absolute inset-0 p-8 flex flex-col justify-end items-center text-center space-y-3">
                  <h3 class="text-3xl font-brand font-bold text-white tracking-tight">{category.name}</h3>
                  <div class="w-12 h-0.5 bg-terracotta transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
                  <span class="text-xs font-bold uppercase tracking-[0.2em] text-white/90 opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-500">
                    Ver colección
                  </span>
                </div>
              </a>
            )
          })}
        </div>
      </section>

      {/* Sección de Subcategorías (Explora por Estilo) */}
      <section class="space-y-12">
        <div class="flex items-end justify-between border-b border-terracotta/10 pb-6">
          <h2 class="text-3xl font-brand font-bold text-espresso">Explora por Estilo</h2>
          <p class="text-terracotta font-medium hidden sm:block">Encuentra exactamente lo que buscas</p>
        </div>

        <div class={`grid grid-cols-2 ${gridColsSm} ${gridColsLg} gap-x-8 gap-y-10 justify-center justify-items-center w-fit mx-auto`}>
          {allSubcategories.map((sub) => {
            const displaySubImage = subcategoryImages[sub.slug] || (sub.photoKey ? `/api/media/${sub.photoKey}` : null)
            return (
              <a
                href={`/catalogo?subcategory=${sub.id}`}
                class="group flex flex-col items-center space-y-4 text-center max-w-[160px]"
              >
                <div class="relative w-full aspect-square overflow-hidden rounded-full border-4 border-white shadow-sm ring-1 ring-terracotta/5 transition-all duration-500 group-hover:ring-terracotta/20 group-hover:shadow-md">
                  {displaySubImage ? (
                    <img
                      src={displaySubImage}
                      alt={sub.name}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                    />
                  ) : (
                    <div class="h-full w-full bg-linen flex items-center justify-center">
                      <span class="text-3xl font-brand text-terracotta/20">{sub.name[0]}</span>
                    </div>
                  )}
                </div>
                <div>
                  <p class="text-sm font-bold text-espresso group-hover:text-terracotta transition-colors">{sub.name}</p>
                  <p class="text-[10px] uppercase tracking-widest text-espresso/40">Selección Saris</p>
                </div>
              </a>
            )
          })}
        </div>
      </section>

      {/* Punto 5: Colección por Temporada / Lookbook (Diseño Editorial) */}
      <section class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7 relative group overflow-hidden rounded-[3rem] aspect-[16/10] lg:aspect-auto lg:h-[600px]">
          <img
            src="https://images.unsplash.com/photo-1490481651871-ab68de25d43d?q=80&w=2070&auto=format&fit=crop"
            alt="Colección de Temporada"
            class="h-full w-full object-cover transition-transform duration-1000 group-hover:scale-105"
          />
          <div class="absolute inset-0 bg-espresso/10 group-hover:bg-transparent transition-colors duration-700"></div>
        </div>
        
        <div class="lg:col-span-5 space-y-8 lg:pl-12">
          <div class="space-y-4">
            <span class="text-terracotta font-bold tracking-[0.4em] uppercase text-[10px]">Edición Limitada</span>
            <h2 class="text-5xl sm:text-6xl font-brand font-bold text-espresso leading-[1.1]">Esencia de <br/><span class="italic text-terracotta">Invierno</span></h2>
            <p class="text-lg text-espresso/70 font-light leading-relaxed">
              Nuestra nueva colección captura la calidez de los momentos compartidos. Materiales nobles, cortes atemporales y una paleta de colores inspirada en la naturaleza.
            </p>
          </div>
          
          <div class="pt-4 flex flex-col space-y-6">
            <a href="/catalogo" class="inline-flex items-center gap-4 text-espresso group">
              <span class="w-12 h-px bg-terracotta group-hover:w-20 transition-all duration-500"></span>
              <span class="text-sm font-bold uppercase tracking-widest group-hover:text-terracotta transition-colors">Explorar el Lookbook</span>
            </a>
            
            <div class="flex gap-8 border-t border-terracotta/10 pt-8">
              <div class="space-y-1">
                <p class="text-2xl font-brand font-bold text-espresso">100%</p>
                <p class="text-[10px] uppercase tracking-widest text-espresso/40 font-bold">Lino Orgánico</p>
              </div>
              <div class="space-y-1">
                <p class="text-2xl font-brand font-bold text-espresso">Hecho</p>
                <p class="text-[10px] uppercase tracking-widest text-espresso/40 font-bold">Con Amor</p>
              </div>
            </div>
          </div>
        </div>
      </section>


      {/* Punto 4: Franja de Confianza (Trust Signals) */}
      <section class="py-16 px-8 rounded-[3rem] bg-linen/50 border border-terracotta/5">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 sm:gap-16">
          {/* Item 1: Envíos */}
          <div class="flex flex-col items-center text-center space-y-4 group">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
              </svg>
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-bold text-espresso">Envíos a todo el país</h3>
              <p class="text-sm text-espresso/60 leading-relaxed max-w-[200px]">Recibe tus piezas favoritas en la comodidad de tu hogar.</p>
            </div>
          </div>

          {/* Item 2: WhatsApp */}
          <div class="flex flex-col items-center text-center space-y-4 group">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-bold text-espresso">Atención Personalizada</h3>
              <p class="text-sm text-espresso/60 leading-relaxed max-w-[200px]">Estamos contigo vía WhatsApp para resolver cualquier duda.</p>
            </div>
          </div>

          {/* Item 3: Calidad */}
          <div class="flex flex-col items-center text-center space-y-4 group">
            <div class="w-16 h-16 rounded-full bg-white flex items-center justify-center shadow-sm group-hover:scale-110 transition-transform duration-500">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" />
              </svg>
            </div>
            <div class="space-y-2">
              <h3 class="text-lg font-bold text-espresso">Calidad Saris</h3>
              <p class="text-sm text-espresso/60 leading-relaxed max-w-[200px]">Cada pieza es seleccionada bajo los más altos estándares.</p>
            </div>
          </div>
        </div>
      </section>

      {/* Punto 3: Novedades o Best Sellers (Productos Destacados) */}
      {featuredProducts.length > 0 && (
        <section id="productos-destacados" class="space-y-12">
          <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-terracotta/10 pb-8">
            <div class="space-y-2">
              <h2 class="text-4xl font-brand font-bold text-espresso">Selección Especial</h2>
              <p class="text-espresso/60">Nuestras piezas más deseadas y novedades recién llegadas.</p>
            </div>
            <a href="/catalogo" class="text-sm font-bold uppercase tracking-widest text-terracotta hover:text-espresso transition-colors flex items-center gap-2 group">
              Ver todo el catálogo
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </a>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-12">
            {featuredProducts.map((product) => {
              const hasDiscount = product.discountedPrice !== null;

              return (
                <div class="group flex flex-col space-y-4">
                  {/* Imagen del Producto */}
                  <div class="relative aspect-[3/4] overflow-hidden rounded-[2rem] bg-linen shadow-sm group-hover:shadow-md transition-shadow duration-500">
                    {product.mainPhotoKey ? (
                      <img
                        src={`/api/media/${product.mainPhotoKey}`}
                        alt={product.name}
                        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                      />
                    ) : (
                      <div class="h-full w-full bg-gradient-to-br from-linen to-terracotta/5 flex items-center justify-center">
                        <span class="text-terracotta/20 font-brand text-4xl">{product.name[0]}</span>
                      </div>
                    )}
                    
                    {/* Badges */}
                    <div class="absolute top-4 left-4 flex flex-col gap-2">
                      {hasDiscount && (
                        <span class="bg-terracotta text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full shadow-sm">
                          Oferta
                        </span>
                      )}
                    </div>

                    {/* Botón rápido (Overlay) */}
                    <div class="absolute inset-0 bg-espresso/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                      <a 
                        href={`/producto/${product.slug}`}
                        class="w-full bg-white/95 backdrop-blur-sm text-espresso text-[10px] font-bold py-3.5 rounded-2xl text-center uppercase tracking-widest hover:bg-white transition-all shadow-xl translate-y-4 group-hover:translate-y-0 duration-500"
                      >
                        Ver detalles
                      </a>
                    </div>
                  </div>

                  {/* Información del Producto */}
                  <div class="space-y-1 px-1 text-center sm:text-left">
                    <p class="text-[10px] uppercase tracking-widest text-espresso/40 font-bold">{product.brandName || 'Saris Collection'}</p>
                    <h3 class="text-xl font-brand font-bold text-espresso group-hover:text-terracotta transition-colors leading-tight">
                      <a href={`/producto/${product.slug}`}>{product.name}</a>
                    </h3>
                    <div class="flex items-center justify-center sm:justify-start gap-3">
                      {hasDiscount ? (
                        <>
                          <span class="text-lg font-bold text-terracotta">{formatPrice(product.discountedPrice!)}</span>
                          <span class="text-sm text-espresso/30 line-through">{formatPrice(product.basePrice)}</span>
                        </>
                      ) : (
                        <span class="text-lg font-bold text-espresso/80">{formatPrice(product.basePrice)}</span>
                      )}
                    </div>
                  </div>
                </div>
              );
            })}
          </div>


        </section>
      )}

      {/* Punto 6: Prueba Social (Social Proof) */}
      <section class="space-y-16 py-24">
        <div class="text-center space-y-4">
          <h2 class="text-4xl font-brand font-bold text-espresso">Lo que dicen nuestras clientas</h2>
          <div class="flex justify-center gap-1 text-terracotta">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-current" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-espresso/60 max-w-xl mx-auto italic">"Arreglarse es un acto de amor propio, y nos encanta acompañarte en ese proceso."</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {/* Testimonio 1 */}
          <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-terracotta/5 space-y-6 flex flex-col justify-between hover:shadow-md transition-shadow">
            <p class="text-lg font-brand leading-relaxed text-espresso/80 italic">
              "La calidad de las telas es excepcional. Compré una blusa de lino y se ha vuelto mi pieza favorita. Se nota la curaduría en cada detalle."
            </p>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-linen flex items-center justify-center font-bold text-terracotta text-sm">MG</div>
              <div>
                <p class="font-bold text-espresso text-sm">María García</p>
                <p class="text-[10px] uppercase tracking-widest text-espresso/40">Compra Verificada</p>
              </div>
            </div>
          </div>

          {/* Testimonio 2 */}
          <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-terracotta/5 space-y-6 flex flex-col justify-between hover:shadow-md transition-shadow">
            <p class="text-lg font-brand leading-relaxed text-espresso/80 italic">
              "El servicio por WhatsApp es increíble. Me ayudaron a elegir mi talla y el envío llegó rapidísimo. Muy recomendadas."
            </p>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-linen flex items-center justify-center font-bold text-terracotta text-sm">CR</div>
              <div>
                <p class="font-bold text-espresso text-sm">Carla Rodríguez</p>
                <p class="text-[10px] uppercase tracking-widest text-espresso/40">Compra Verificada</p>
              </div>
            </div>
          </div>

          {/* Testimonio 3 */}
          <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-terracotta/5 space-y-6 flex flex-col justify-between hover:shadow-md transition-shadow">
            <p class="text-lg font-brand leading-relaxed text-espresso/80 italic">
              "Buscaba algo elegante pero cómodo para el día a día y Saris dio en el clavo. Ya estoy esperando mi siguiente pedido."
            </p>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-linen flex items-center justify-center font-bold text-terracotta text-sm">LM</div>
              <div>
                <p class="font-bold text-espresso text-sm">Lucía Méndez</p>
                <p class="text-[10px] uppercase tracking-widest text-espresso/40">Compra Verificada</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Punto 7: Contacto Directo / Cierre (CTA Final) */}
      {whatsappNumber && (
        <section class="relative overflow-hidden rounded-[3rem] bg-espresso py-20 px-8 sm:px-16 text-center text-linen shadow-2xl">
          {/* Elementos Decorativos */}
          <div class="absolute -top-24 -left-24 w-64 h-64 bg-terracotta/10 rounded-full blur-3xl"></div>
          <div class="absolute -bottom-24 -right-24 w-64 h-64 bg-terracotta/10 rounded-full blur-3xl"></div>
          
