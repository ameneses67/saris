---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import DiscountsManager from '../../../components/admin/DiscountsManager'
import { getDb } from '../../../db'
import { discounts, categories, subcategories, brands, products } from '../../../db/schema'
import { asc, desc } from 'drizzle-orm'

const db = getDb()

const [
  discountRows,
  categoryRows,
  subcategoryRows,
  brandRows,
  productRows,
] = await Promise.all([
  db.select().from(discounts).orderBy(desc(discounts.createdAt)),
  db.select({ id: categories.id, name: categories.name }).from(categories).orderBy(asc(categories.sortOrder), asc(categories.name)),
  db.select({ id: subcategories.id, name: subcategories.name }).from(subcategories).orderBy(asc(subcategories.name)),
  db.select({ id: brands.id, name: brands.name }).from(brands).orderBy(asc(brands.sortOrder), asc(brands.name)),
  db.select({ id: products.id, name: products.name }).from(products).orderBy(asc(products.name)),
])
---

<AdminLayout title="Descuentos">
  <DiscountsManager
    client:load
    initialDiscounts={discountRows}
    categories={categoryRows}
    subcategories={subcategoryRows}
    brands={brandRows}
    products={productRows}
  />
</AdminLayout>
