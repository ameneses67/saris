---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getDb } from '../../../db'
import { settings } from '../../../db/schema'
import SettingsManager from '../../../components/admin/SettingsManager'

// Solo administradores pueden acceder
if (Astro.locals.user?.role !== 'admin') {
  return Astro.redirect('/admin')
}

const db = getDb()
const allSettings = await db.select().from(settings).orderBy(settings.key)
---

<AdminLayout title="Configuración">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Configuración</h1>
    <p class="mt-1 text-sm text-gray-500">Ajustes generales del sitio.</p>
  </div>

  <SettingsManager client:load initialSettings={allSettings} />
</AdminLayout>
